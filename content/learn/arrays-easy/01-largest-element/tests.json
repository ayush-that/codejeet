    "visible": true
  },
  {
    "name": "max at end",
    "stdin": "6\n1 2 3 4 5 100\n",
    "expectedStdout": "100",
    "visible": false
  },
  {
    "name": "duplicates of max",
    "stdin": "5\n5 1 5 5 2\n",
    "expectedStdout": "5",
    "visible": false
  }
